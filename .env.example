# ============================================
# VedoraAI Environment Configuration
# ============================================
# Copy this file to backend/.env and fill in your values

# ── App ──────────────────────────────────────
APP_NAME=VedoraAI
APP_ENV=development
DEBUG=true
API_VERSION=v1
SECRET_KEY=your-super-secret-key-change-this-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Database ─────────────────────────────────
# SQLite (default for development - no setup needed)
DATABASE_URL=sqlite+aiosqlite:///./vedoraai.db
# PostgreSQL (for production)
# DATABASE_URL=postgresql+asyncpg://vedora:vedora_secret@localhost:5432/vedoraai

# ── JWT Authentication ───────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Google Gemini (AI Coach) ─────────────────
# Get your key from https://aistudio.google.com/apikey
# Optional: Coach works in fallback mode without this
GEMINI_API_KEY=your-gemini-api-key

# ── Email (SMTP) — Optional ──────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ── OTP ──────────────────────────────────────
OTP_EXPIRY_MINUTES=5

# ── Frontend URL ─────────────────────────────
FRONTEND_URL=http://localhost:3000
